include README.md
include LICENSE
include pyproject.toml
include CHANGELOG.md
include CONTRIBUTING.md
include CITATION.cff
recursive-include docs *.md
recursive-include tests *.py *.csv *.tsv
recursive-include examples/toy *.md *.tsv *.fa
prune .github
prune packaging
prune build
prune dist
prune outlimer_results
prune test_data
global-exclude .DS_Store
global-exclude *.py[cod]
global-exclude __pycache__
